generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User {
  id               String              @id @default(auto()) @map("_id") @db.ObjectId
  clerkId          String              @unique
  email            String              @unique
  name             String
  avatarUrl        String?
  workspaces       WorkspaceMember[]
  teamspaces       TeamspaceMember[]   @relation("TeamspaceMembership")
  plots            Plot[]              @relation("PlotCreator")

  conversationMemberships ConversationMember[]
  sentMessages            Message[]

  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
}

model Workspace {
  id            String            @id @default(auto()) @map("_id") @db.ObjectId
  name          String
  description   String?
  logoUrl       String?
  inviteCode    String            @unique
  members       WorkspaceMember[]
  teamspaces    Teamspace[]
  conversations Conversation[]
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
}

model WorkspaceMember {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  userId      String    @db.ObjectId
  workspaceId String    @db.ObjectId
  role        Role      @default(MEMBER)

  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([userId, workspaceId])
}

// ---------------------------------------------------------------------------
// Teamspace → Folder → Plot hierarchy (strict: no nested folders)
// ---------------------------------------------------------------------------

model Teamspace {
  id          String              @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  description String?
  emoji       String?             @default("📁")
  workspaceId String              @db.ObjectId
  workspace   Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  folders     Folder[]
  plots       Plot[]
  members     TeamspaceMember[]

  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
}

model TeamspaceMember {
  id          String      @id @default(auto()) @map("_id") @db.ObjectId
  userId      String      @db.ObjectId
  teamspaceId String      @db.ObjectId
  role        TeamRole    @default(MEMBER)

  user        User        @relation("TeamspaceMembership", fields: [userId], references: [id], onDelete: Cascade)
  teamspace   Teamspace   @relation(fields: [teamspaceId], references: [id], onDelete: Cascade)

  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@unique([userId, teamspaceId])
}

model Folder {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  emoji       String?   @default("📂")
  teamspaceId String    @db.ObjectId
  teamspace   Teamspace @relation(fields: [teamspaceId], references: [id], onDelete: Cascade)

  plots       Plot[]

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Plot {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  emoji       String?   @default("📄")
  color       String?   @default("#3b82f6")

  teamspaceId String    @db.ObjectId
  teamspace   Teamspace @relation(fields: [teamspaceId], references: [id], onDelete: Cascade)

  folderId    String?   @db.ObjectId
  folder      Folder?   @relation(fields: [folderId], references: [id], onDelete: SetNull)

  isPrivate   Boolean   @default(false)

  creatorId   String    @db.ObjectId
  creator     User      @relation("PlotCreator", fields: [creatorId], references: [id], onDelete: Cascade)

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

// ---------------------------------------------------------------------------
// Chat System: Conversation → Message (DM, Group DM, Channel, Plot Activity)
// ---------------------------------------------------------------------------

model Conversation {
  id              String              @id @default(auto()) @map("_id") @db.ObjectId
  type            ConversationType
  workspaceId     String              @db.ObjectId
  workspace       Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  name            String?
  description     String?
  visibility      ChannelVisibility?  @default(PUBLIC)
  createdById     String?             @db.ObjectId

  lastMessageAt   DateTime?
  lastMessageText String?
  lastSenderId    String?             @db.ObjectId

  members         ConversationMember[]
  messages        Message[]

  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  @@index([workspaceId, type])
  @@index([workspaceId, lastMessageAt(sort: Desc)])
}

model ConversationMember {
  id              String        @id @default(auto()) @map("_id") @db.ObjectId
  conversationId  String        @db.ObjectId
  userId          String        @db.ObjectId
  lastReadAt      DateTime      @default(now())

  conversation    Conversation  @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt       DateTime      @default(now())

  @@unique([conversationId, userId])
  @@index([userId])
}

model Message {
  id              String        @id @default(auto()) @map("_id") @db.ObjectId
  conversationId  String        @db.ObjectId
  senderId        String        @db.ObjectId
  content         String
  mentions        String[]      @default([])
  isSystem        Boolean       @default(false)

  conversation    Conversation  @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender          User          @relation(fields: [senderId], references: [id], onDelete: Cascade)

  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([conversationId, createdAt(sort: Desc)])
}

enum ConversationType {
  DM
  GROUP_DM
  CHANNEL
  PLOT_ACTIVITY
}

enum ChannelVisibility {
  PUBLIC
  PRIVATE
}

enum Role {
  OWNER
  ADMIN
  MEMBER
}

enum TeamRole {
  ADMIN
  MEMBER
}
